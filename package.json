{
  "name": "@asktian/mcp-server",
  "version": "0.3.0",
  "description": "MCP server for asktian — Chinese metaphysics inside your AI assistant",
  "license": "MIT",
  "type": "module",
  "bin": {
    "asktian-mcp": "dist/server.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/server.js",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "start:http": "ASKTIAN_MCP_HTTP=1 node dist/server.js",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "asktian",
    "bazi",
    "qimen",
    "fengshui",
    "chinese-metaphysics",
    "ai-assistant",
    "claude",
    "decision-making"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/douglasgan/asktian-mcp.git"
  },
  "homepage": "https://asktian.com/agents",
  "bugs": {
    "url": "https://github.com/douglasgan/asktian-mcp/issues"
  }
}
